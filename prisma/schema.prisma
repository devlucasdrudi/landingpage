generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid()) @db.UniqueIdentifier
  name          String?          @db.NVarChar(160)
  email         String           @unique @db.NVarChar(255)
  emailVerified DateTime?
  passwordHash  String?          @db.NVarChar(255)
  image         String?          @db.NVarChar(1000)
  role          String           @default("CUSTOMER") @db.NVarChar(20)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  addresses     Address[]
  carts         Cart[]
  wishlist      Wishlist?
  orders        Order[]
  reviews       Review[]
  promoUsages   PromoCodeUsage[]
  stockAlerts   StockAlert[]

  @@map("Users")
}

model Address {
  id           String   @id @default(uuid()) @db.UniqueIdentifier
  userId       String?  @db.UniqueIdentifier
  label        String?  @db.NVarChar(80)
  recipient    String   @db.NVarChar(160)
  phone        String?  @db.NVarChar(32)
  cep          String   @db.NVarChar(16)
  street       String   @db.NVarChar(180)
  number       String   @db.NVarChar(40)
  complement   String?  @db.NVarChar(120)
  neighborhood String   @db.NVarChar(120)
  city         String   @db.NVarChar(120)
  state        String   @db.NVarChar(2)
  country      String   @default("BR") @db.NVarChar(2)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("Addresses")
}

model Category {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  name        String    @db.NVarChar(120)
  slug        String    @unique @db.NVarChar(160)
  description String?   @db.NVarChar(1000)
  imageUrl    String?   @db.NVarChar(1000)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("Categories")
}

model Collection {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  name        String    @db.NVarChar(120)
  slug        String    @unique @db.NVarChar(160)
  description String?   @db.NVarChar(1200)
  heroImage   String?   @db.NVarChar(1000)
  isFeatured  Boolean   @default(false)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("Collections")
}

model Product {
  id             String           @id @default(uuid()) @db.UniqueIdentifier
  categoryId     String?          @db.UniqueIdentifier
  collectionId   String?          @db.UniqueIdentifier
  name           String           @db.NVarChar(180)
  slug           String           @unique @db.NVarChar(200)
  description    String?          @db.NVarChar(Max)
  details        String?          @db.NVarChar(Max)
  price          Decimal          @db.Decimal(12, 2)
  compareAtPrice Decimal?         @db.Decimal(12, 2)
  status         String           @default("DRAFT") @db.NVarChar(20)
  isFeatured     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collection     Collection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  variants       ProductVariant[]
  images         ProductImage[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  stockAlerts    StockAlert[]

  @@index([categoryId])
  @@index([collectionId])
  @@map("Products")
}

model ProductVariant {
  id              String       @id @default(uuid()) @db.UniqueIdentifier
  productId       String       @db.UniqueIdentifier
  sku             String       @unique @db.NVarChar(80)
  size            String       @db.NVarChar(32)
  colorName       String       @db.NVarChar(80)
  colorHex        String?      @db.NVarChar(12)
  priceAdjustment Decimal      @default(0) @db.Decimal(12, 2)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory       Inventory?
  images          ProductImage[]
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([productId])
  @@map("ProductVariants")
}

model Inventory {
  id                String         @id @default(uuid()) @db.UniqueIdentifier
  variantId         String         @unique @db.UniqueIdentifier
  quantity          Int            @default(0)
  reservedQuantity  Int            @default(0)
  lowStockThreshold Int            @default(3)
  updatedAt         DateTime       @updatedAt
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("Inventory")
}

model ProductImage {
  id          String          @id @default(uuid()) @db.UniqueIdentifier
  productId   String          @db.UniqueIdentifier
  variantId   String?         @db.UniqueIdentifier
  url         String          @db.NVarChar(1000)
  alt         String?         @db.NVarChar(180)
  sortOrder   Int             @default(0)
  isPrimary   Boolean         @default(false)
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId])
  @@index([variantId])
  @@map("ProductImages")
}

model PromoCode {
  id              String             @id @default(uuid()) @db.UniqueIdentifier
  code            String             @unique @db.NVarChar(40)
  description     String?            @db.NVarChar(300)
  discountType    String             @db.NVarChar(20)
  discountValue   Decimal            @db.Decimal(12, 2)
  minimumSubtotal Decimal?           @db.Decimal(12, 2)
  startsAt        DateTime?
  expiresAt       DateTime?
  maxUses         Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  usages          PromoCodeUsage[]

  @@map("PromoCodes")
}

model PromoCodeUsage {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  promoCodeId String    @db.UniqueIdentifier
  userId      String?   @db.UniqueIdentifier
  orderId     String?   @db.UniqueIdentifier
  usedAt      DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([promoCodeId])
  @@index([userId])
  @@index([orderId])
  @@map("PromoCodeUsage")
}

model Cart {
  id         String     @id @default(uuid()) @db.UniqueIdentifier
  userId     String?    @db.UniqueIdentifier
  guestToken String?    @db.NVarChar(120)
  status     String     @default("ACTIVE") @db.NVarChar(20)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      CartItem[]

  @@index([userId])
  @@index([guestToken])
  @@map("Carts")
}

model CartItem {
  id        String         @id @default(uuid()) @db.UniqueIdentifier
  cartId    String         @db.UniqueIdentifier
  productId String         @db.UniqueIdentifier
  variantId String         @db.UniqueIdentifier
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cartId, variantId])
  @@index([productId])
  @@map("CartItems")
}

model Wishlist {
  id        String         @id @default(uuid()) @db.UniqueIdentifier
  userId    String         @unique @db.UniqueIdentifier
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]

  @@map("Wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid()) @db.UniqueIdentifier
  wishlistId String   @db.UniqueIdentifier
  productId  String   @db.UniqueIdentifier
  createdAt  DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@map("WishlistItems")
}

model Order {
  id                 String           @id @default(uuid()) @db.UniqueIdentifier
  userId             String?          @db.UniqueIdentifier
  orderNumber        String           @unique @db.NVarChar(40)
  status             String           @default("PENDING") @db.NVarChar(20)
  subtotal           Decimal          @db.Decimal(12, 2)
  discountTotal      Decimal          @default(0) @db.Decimal(12, 2)
  shippingTotal      Decimal          @default(0) @db.Decimal(12, 2)
  giftWrapTotal      Decimal          @default(0) @db.Decimal(12, 2)
  total              Decimal          @db.Decimal(12, 2)
  currency           String           @default("BRL") @db.NVarChar(3)
  customerEmail      String           @db.NVarChar(255)
  customerName       String           @db.NVarChar(160)
  shippingMethod     String?          @db.NVarChar(80)
  shippingAddress    String           @db.NVarChar(Max)
  billingAddress     String?          @db.NVarChar(Max)
  stripePaymentId    String?          @db.NVarChar(255)
  inventoryExpiresAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payments           Payment[]
  promoUsages        PromoCodeUsage[]

  @@index([userId])
  @@map("Orders")
}

model OrderItem {
  id                  String         @id @default(uuid()) @db.UniqueIdentifier
  orderId             String         @db.UniqueIdentifier
  productId           String?        @db.UniqueIdentifier
  variantId           String?        @db.UniqueIdentifier
  productNameSnapshot String         @db.NVarChar(180)
  skuSnapshot         String         @db.NVarChar(80)
  sizeSnapshot        String?        @db.NVarChar(32)
  colorSnapshot       String?        @db.NVarChar(80)
  unitPrice           Decimal        @db.Decimal(12, 2)
  quantity            Int
  subtotal            Decimal        @db.Decimal(12, 2)
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product?        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("OrderItems")
}

model Payment {
  id                    String        @id @default(uuid()) @db.UniqueIdentifier
  orderId               String        @db.UniqueIdentifier
  provider              String        @default("stripe") @db.NVarChar(40)
  method                String        @db.NVarChar(20)
  status                String        @default("PENDING") @db.NVarChar(20)
  amount                Decimal       @db.Decimal(12, 2)
  installments          Int?
  stripePaymentIntentId String?       @unique @db.NVarChar(255)
  pixQrCode             String?       @db.NVarChar(Max)
  boletoUrl             String?       @db.NVarChar(1000)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("Payments")
}

model Review {
  id        String        @id @default(uuid()) @db.UniqueIdentifier
  productId String        @db.UniqueIdentifier
  userId    String?       @db.UniqueIdentifier
  rating    Int
  title     String?       @db.NVarChar(140)
  body      String?       @db.NVarChar(2000)
  isApproved Boolean      @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  images    ReviewImage[]

  @@index([productId])
  @@index([userId])
  @@map("Reviews")
}

model ReviewImage {
  id       String @id @default(uuid()) @db.UniqueIdentifier
  reviewId String @db.UniqueIdentifier
  url      String @db.NVarChar(1000)
  alt      String? @db.NVarChar(180)
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("ReviewImages")
}

model StockAlert {
  id        String          @id @default(uuid()) @db.UniqueIdentifier
  productId String          @db.UniqueIdentifier
  userId    String?         @db.UniqueIdentifier
  email     String          @db.NVarChar(255)
  size      String?         @db.NVarChar(32)
  color     String?         @db.NVarChar(80)
  sentAt    DateTime?
  createdAt DateTime        @default(now())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@map("StockAlerts")
}
